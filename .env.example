# --- salut_bot специфичные параметры ---
# Общие параметры (LLM, GigaChat, DB, Redis, публичный URL) — в shared.env
# DB_HOST и REDIS_HOST задаются через environment: в docker-compose.yml

YANDEX_API_KEY=your_yandex_api_key

FAISS_INDEX_PATH=./faiss_index_path
MAPS_DIR=/app/maps
EMBEDDING_MODEL=bge-m3
EMBEDDING_MODELS_BASE_DIR=/app/embedding_models

GITHUB_TOKEN=your_github_token
GITHUB_USER=your_github_user

ADMIN_PASSWORD=changeme
PLANTNET_API_KEY=your_plantnet_api_key
